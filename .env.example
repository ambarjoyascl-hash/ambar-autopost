# ─── Meta / Graph API ──────────────────────────────────────────────
# App de Meta (developers.facebook.com → App settings → Basic)
META_APP_ID=
META_APP_SECRET=
# Versión de la Graph API (opcional; por defecto v21.0)
GRAPH_VERSION=v21.0

# ─── Firebase Admin (Service Account) ──────────────────────────────
# De la consola de Firebase → Project settings → Service accounts → Generate key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Pega la private key COMPLETA entre comillas. En Vercel los saltos de línea
# van como \n literales; el código los normaliza.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Seguridad de los crons ────────────────────────────────────────
# String aleatorio para proteger /api/cron/*. Genera uno con:
#   openssl rand -hex 32
CRON_SECRET=

# ─── Shopify (cobro del live de oro) ───────────────────────────────
# Dominio de la API de tu tienda (el .myshopify.com, no el .cl):
SHOPIFY_STORE_DOMAIN=ambar-8632.myshopify.com
# Token de Admin API con permiso write_draft_orders (para generar el link de
# pago de cada pieza). Shopify admin → Configuración → Apps y canales de venta
# → Desarrollar apps → crear app → Admin API scopes: write_draft_orders,
# read_draft_orders (y opcional write_customers para el registro) → Instalar → "Token de acceso de Admin API".
SHOPIFY_ADMIN_TOKEN=
SHOPIFY_API_VERSION=2024-10


# ─── App del live de oro (Vercel) ──────────────────────────────────
# Contraseña de tu panel /admin.html (la eliges tú):
ADMIN_PASSWORD=
# Vercel Blob: se crea solo al conectar un "Blob store" en Vercel
# (Storage → Create → Blob). Vercel agrega BLOB_READ_WRITE_TOKEN automáticamente.
