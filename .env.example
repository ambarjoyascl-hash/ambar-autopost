# ─── Meta / Graph API ──────────────────────────────────────────────
# App de Meta (developers.facebook.com → App settings → Basic)
META_APP_ID=
META_APP_SECRET=
# Versión de la Graph API (opcional; por defecto v21.0)
GRAPH_VERSION=v21.0

# ─── Firebase Admin (Service Account) ──────────────────────────────
# De la consola de Firebase → Project settings → Service accounts → Generate key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Pega la private key COMPLETA entre comillas. En Vercel los saltos de línea
# van como \n literales; el código los normaliza.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Seguridad de los crons ────────────────────────────────────────
# String aleatorio para proteger /api/cron/*. Genera uno con:
#   openssl rand -hex 32
CRON_SECRET=

# ─── Shopify (opcional, solo si usas lib/shopify-to-queue.js) ──────
SHOPIFY_STORE_DOMAIN=tu-tienda.myshopify.com
SHOPIFY_ADMIN_TOKEN=
SHOPIFY_API_VERSION=2024-04

# ─── Mercado Pago (tienda de oro) ──────────────────────────────────
# Access Token de PRODUCCIÓN de tu cuenta de Mercado Pago (Chile).
# Mercado Pago → Tus integraciones → tu app → Credenciales de producción.
# (Para probar sin cobrar de verdad, usa el Access Token de PRUEBA.)
MP_ACCESS_TOKEN=
# Moneda (Chile = CLP). Cámbiala solo si tu cuenta MP es de otro país.
MP_CURRENCY=CLP
# (Opcional) URL pública del sitio. Si no la pones, se detecta sola en Vercel.
# Úsala solo si el webhook o el retorno de pago apuntan mal.
PUBLIC_BASE_URL=
