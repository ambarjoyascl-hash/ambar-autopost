# ─── Panel (seguridad) ─────────────────────────────────────────────
# Contraseña para entrar al panel web. OBLIGATORIA: sin ella el panel
# responde 500 y nadie puede usarlo (así nadie ajeno accede a tus tokens).
# Genera una larga y guárdala:  openssl rand -hex 16
APP_PASSWORD=

# ─── IA (generación de contenido) ──────────────────────────────────
# API key de Anthropic (Claude) para generar el plan semanal.
# https://console.anthropic.com  → API Keys
ANTHROPIC_API_KEY=
# Modelo a usar (opcional; por defecto claude-sonnet-5)
CONTENT_MODEL=claude-sonnet-5

# ─── Zona horaria por defecto ──────────────────────────────────────
# Se usa para agendar los posts a la hora local. Ej: America/Santiago
DEFAULT_TIMEZONE=America/Santiago

# ─── Meta / Graph API ──────────────────────────────────────────────
# App de Meta (developers.facebook.com → App settings → Basic).
# Se usan para refrescar los tokens de larga duración de cada marca.
META_APP_ID=
META_APP_SECRET=
# Versión de la Graph API (opcional; por defecto v21.0)
GRAPH_VERSION=v21.0

# ─── Firebase Admin (Service Account) ──────────────────────────────
# Consola de Firebase → Project settings → Service accounts → Generate key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Pega la private key COMPLETA entre comillas. En Vercel los saltos de línea
# van como \n literales; el código los normaliza.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Seguridad de los crons ────────────────────────────────────────
# String aleatorio para proteger /api/cron/*. Genera uno con:
#   openssl rand -hex 32
CRON_SECRET=

# ─── Shopify (opcional; global) ────────────────────────────────────
# Las credenciales de Shopify se guardan POR MARCA desde el panel.
# Esto solo fija la versión de API por defecto si una marca no la especifica.
SHOPIFY_API_VERSION=2024-04
