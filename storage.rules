rules_version = '2';

// Reglas de Firebase Storage para las fotos/videos del live.
// ⚠️ Reemplaza TU_CORREO_ADMIN@gmail.com por tu correo real.
//    Pega esto en Firebase → Storage → Reglas.
service firebase.storage {
  match /b/{bucket}/o {
    match /live/{allPaths=**} {
      allow read: if true;                         // los clientes ven las piezas
      allow write: if request.auth != null
        && request.auth.token.email == 'TU_CORREO_ADMIN@gmail.com'
        && request.resource.size < 200 * 1024 * 1024; // hasta 200 MB (videos)
    }
  }
}
