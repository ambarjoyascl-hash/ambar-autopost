rules_version = '2';

// Reglas de seguridad de Firestore para la tienda de Ámbar Joyas.
// ⚠️ Reemplaza TU_CORREO_ADMIN@gmail.com por tu correo real (el mismo de
//    firebase-config.js) y pega estas reglas en:
//    Firebase → Firestore Database → Reglas.
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'TU_CORREO_ADMIN@gmail.com';
    }

    // Catálogo: todos pueden ver; solo la admin puede crear/editar/borrar.
    match /products/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Órdenes: las crea el servidor (Vercel) con permisos de Admin SDK, así
    // que el cliente no escribe aquí. Cada cliente puede leer las suyas; la
    // admin puede leer todas.
    match /orders/{id} {
      allow read: if isAdmin() || (
        request.auth != null && resource.data.uid == request.auth.uid
      );
      allow write: if false; // solo el servidor (Admin SDK) escribe órdenes
    }
  }
}
